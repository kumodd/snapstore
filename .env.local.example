# SnapStore — Environment Variables Template
# Copy this file to .env.local and fill in your actual values.
#
# IMPORTANT: .env.local is in .gitignore — never commit it to git.
# For production deploys, set these in your hosting platform's
# environment variables UI (Vercel / Netlify / Cloudflare Pages etc.)

# ── Supabase ──────────────────────────────────────────────────────────
# Found at: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── App URL ───────────────────────────────────────────────────────────
# Local development:
VITE_APP_URL=http://localhost:5173
# Production (change to your deployed URL):
# VITE_APP_URL=https://your-app.vercel.app

# ── Razorpay (optional — billing features) ────────────────────────────
# Found at: Razorpay Dashboard → Settings → API Keys
# Leave blank to disable billing UI
VITE_RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID_HERE
